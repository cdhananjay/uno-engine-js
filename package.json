{
    "name": "uno-engine-js",
    "version": "0.2.0",
    "description": "A headless, zero-dependency uno game logic engine written in TypeScript.",
    "keywords": [
        "uno",
        "game",
        "engine"
    ],
    "homepage": "https://github.com/cdhananjay/uno-engine-js#readme",
    "bugs": {
        "url": "https://github.com/cdhananjay/uno-engine-js/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/cdhananjay/uno-engine-js.git"
    },
    "license": "ISC",
    "author": "Dhananjay Chavan",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "clean": "rm -rf dist",
        "prepublishOnly": "npm run clean && npm run build",
        "prettier": "npx prettier --write .",
        "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
    },
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "@types/node": "^25.3.3",
        "jest": "^30.2.0",
        "prettier": "^3.8.1",
        "ts-jest": "^29.4.6",
        "typescript": "^5.9.3"
    }
}
